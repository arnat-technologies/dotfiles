[ ! -z "$DEVCONTAINER_RAM_FOLDER" ] || export DEVCONTAINER_RAM_FOLDER="node_modules"
[ ! -z "$DEVCONTAINER_DOTFILES" ] || export DEVCONTAINER_DOTFILES="rsurjano/dotfiles"
[ ! -z "$DEVCONTAINER_TARGET" ] || export DEVCONTAINER_TARGET="~/.user/dotfiles"
[ ! -z "$DEVCONTAINER_SHELL" ] || export DEVCONTAINER_SHELL="/bin/zsh"
[ ! -z "$DEVCONTAINER_DOCKERFILE" ] || export DEVCONTAINER_DOCKERFILE="Dockerfile"
